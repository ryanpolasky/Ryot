{
  "name": "ryot",
  "version": "1.0.0",
  "private": true,
  "description": "Ryot - an open-source League of Legends companion: OP.GG-style stats, Porofessor-style live game scout, and a Blitz-style in-game overlay. Self-hostable for you and your friends.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel --filter ./apps/server --filter ./apps/web dev",
    "dev:server": "pnpm --filter @lc/server dev",
    "dev:web": "pnpm --filter @lc/web dev",
    "dev:overlay": "pnpm --filter @lc/overlay dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:web": "pnpm --filter @lc/web lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r exec rm -rf dist .next node_modules/.cache"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
