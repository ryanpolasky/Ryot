# ── Build stage ──────────────────────────────────────────────
FROM node:22-bookworm-slim AS build
RUN corepack enable
WORKDIR /app

# Baked into the client bundle: the URL the *browser* uses to reach the API.
ARG NEXT_PUBLIC_API_BASE=http://localhost:4000
ENV NEXT_PUBLIC_API_BASE=$NEXT_PUBLIC_API_BASE

# Public canonical site URL (SEO/OG). Set to your domain in production.
ARG NEXT_PUBLIC_SITE_URL=https://ryot.lol
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL

# Optional "coming soon" mode: hides the desktop download buttons. Build-time.
ARG NEXT_PUBLIC_COMING_SOON=false
ENV NEXT_PUBLIC_COMING_SOON=$NEXT_PUBLIC_COMING_SOON

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY apps/web/package.json apps/web/
RUN pnpm install --frozen-lockfile --filter @lc/web...

COPY packages/shared packages/shared
COPY apps/web apps/web
RUN pnpm --filter @lc/shared build && pnpm --filter @lc/web build

# ── Runtime stage ────────────────────────────────────────────
FROM node:22-bookworm-slim AS runtime
RUN corepack enable
WORKDIR /app
ENV NODE_ENV=production

COPY --from=build /app/pnpm-workspace.yaml /app/pnpm-lock.yaml /app/package.json /app/tsconfig.base.json ./
COPY --from=build /app/packages/shared/package.json packages/shared/
COPY --from=build /app/apps/web/package.json apps/web/
RUN pnpm install --prod --frozen-lockfile --filter @lc/web...

COPY --from=build /app/packages/shared/dist packages/shared/dist
COPY --from=build /app/apps/web/.next apps/web/.next
COPY --from=build /app/apps/web/next.config.mjs apps/web/
COPY --from=build /app/apps/web/public apps/web/public

EXPOSE 3000
WORKDIR /app/apps/web
CMD ["pnpm", "start"]
