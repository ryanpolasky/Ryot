# ──────────────────────────────────────────────────────────────
# League Companion configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Your Riot API key.
#   - Development key (expires every 24h): https://developer.riotgames.com
#   - Personal/Production key (no expiry): https://developer.riotgames.com/app-type
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Default platform region used when none is specified in the UI.
# One of: na1 euw1 eun1 kr jp1 br1 la1 la2 oc1 tr1 ru me1 sg2 tw2 vn2
DEFAULT_REGION=na1

# Backend server
PORT=4000
# Comma-separated list of origins allowed to call the API (the web app).
CORS_ORIGINS=http://localhost:3000

# Set to true ONLY if the API runs behind a trusted reverse proxy (nginx, Traefik,
# Cloudflare). It makes Fastify read the real client IP from X-Forwarded-For so the
# per-IP rate limiter works correctly. Leave false when the server is exposed
# directly (the default compose), or clients could spoof the header to bypass it.
TRUST_PROXY=false

# Cache TTLs (seconds)
CACHE_TTL_SUMMONER=300
CACHE_TTL_MATCH=86400
CACHE_TTL_SPECTATOR=20
CACHE_TTL_DDRAGON=3600

# Web app -> backend URL (used by the Next.js app at build/runtime)
NEXT_PUBLIC_API_BASE=http://localhost:4000

# Public canonical URL of the web app. Drives SEO: OG/Twitter tags, canonical,
# sitemap.xml, robots.txt, and the JSON-LD @id/url. Set to your real domain in
# production (no trailing slash). Defaults to https://ryot.lol if unset.
NEXT_PUBLIC_SITE_URL=https://ryot.lol

# Set to true to put the site in "coming soon" mode: the desktop download
# buttons become "coming soon" and the download-page copy changes. This is a
# build-time flag for the web app, so rebuild/redeploy to flip it. Defaults off.
NEXT_PUBLIC_COMING_SOON=false

# Overlay -> backend URL
OVERLAY_API_BASE=http://localhost:4000

# ──────────────────────────────────────────────────────────────
# Build & meta engine (Ryot's own Match-V5 aggregation)
# ──────────────────────────────────────────────────────────────
# Builds, tier lists, and matchups are aggregated from Riot's Match-V5 API
# instead of scraping a third party. This is OFF by default and needs a
# PRODUCTION Riot key (a dev key's rate limit + 24h expiry can't sustain a
# crawl). While off, the build/tier/meta endpoints report "coming soon".
STATS_CRAWL_ENABLED=false
# Platforms whose ranked ladders seed the crawl (comma-separated).
STATS_CRAWL_PLATFORMS=na1,euw1,kr
# Seed depth: "apex" (challenger+grandmaster+master) or "all" (adds league-exp).
STATS_CRAWL_SCOPE=apex
# Recent ranked matches pulled per seeded player each cycle.
STATS_MATCHES_PER_PLAYER=15
# Minutes between crawl cycles (0 = run once at boot, no repeat).
STATS_CYCLE_INTERVAL_MIN=360
# Where the aggregated snapshot is persisted (gzipped JSON), relative to cwd.
STATS_SNAPSHOT_PATH=data/stats-snapshot.json.gz
